# Test Environment Configuration
NODE_ENV=test

# MongoDB Test Database
MONGODB_TEST_URI=mongodb://localhost:27017/mediquick_test

# JWT Secret (for testing)
JWT_SECRET=test_secret_key_do_not_use_in_production

# Admin Security Code (for testing)
ADMIN_SECURITY_CODE=ADMIN_SECRET_CODE

# Email Configuration (test)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=test@example.com
SMTP_PASS=test_password

# Redis Configuration (test)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1

# API Port (for testing)
PORT=3003

# Payment Gateway (test)
RAZORPAY_KEY_ID=test_key
RAZORPAY_KEY_SECRET=test_secret

# File Upload (test)
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Rate Limiting (test)
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration (test)
CORS_ORIGIN=*

# Session Configuration (test)
SESSION_SECRET=test_session_secret
SESSION_TIMEOUT=3600000
